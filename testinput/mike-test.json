{
    "firewall": {
        "state-policy": {
            "established": {
                "action": "accept"
            },
            "invalid": {
                "action": "drop"
            },
            "related": {
                "action": "accept"
            }
        },
        "zones": [
            {
                "default-action": "drop",
                "interfaces": [
                    "eth0",
                    "eth1"
                ],
                "name": "wan"
            },
            {
                "default-action": "accept",
                "interfaces": [
                    "eth4"
                ],
                "name": "lan"
            },
            {
                "default-action": "drop",
                "local-zone": true,
                "name": "local"
            }
        ]
    },
    "interfaces": [
        {
            "ipv4": {
                "addressing": "dhcp"
            },
            "ipv6": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth0",
            "role": "upstream"
        },
        {
            "ipv4": {
                "addressing": "dhcp"
            },
            "ipv6": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth1",
            "role": "upstream"
        },
        {
            "ipv4": {
                "address": [
                    "192.168.8.1/24"
                ],
                "addressing": "static"
            },
            "ipv6": {
                "address": [
                    "2001:db8::1/64"
                ],
                "addressing": "static"
            },
            "mtu": 1500,
            "name": "eth4",
            "role": "downstream"
        }
    ],
    "metrics": {
        "health": {
            "interval": 60
        },
        "statistics": {
            "interval": 150
        }
    },
    "qos": {
        "shaper": [
            {
                "bandwidth": "1000mbit",
                "classes": [
                    {
                        "bandwidth": "100mbit",
                        "id": 10,
                        "match": [
                            {
                                "destination": {
                                    "address": "0.0.0.0/0"
                                },
                                "name": "test",
                                "protocol": "tcp",
                                "source": {
                                    "address": "192.168.1.0/24"
                                }
                            }
                        ],
                        "priority": 10
                    }
                ],
                "default": {
                    "bandwidth": "100mbit"
                },
                "name": "wan-shaper"
            }
        ]
    },
    "services": {
        "syslog": {
            "local": [
                {
                    "facility": "all",
                    "severity": "info"
                }
            ],
            "marker": {
                "enable": true,
                "interval": 1200
            },
            "preserve-fqdn": false
        }
    },
    "uuid": 1769672157
}