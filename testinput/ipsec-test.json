{
    "firewall": {
        "ipv4-rulesets": [
            {
                "default-action": "drop",
                "name": "WAN-LAN-ipv4",
                "rules": [
                    {
                        "action": "accept",
                        "destination": {
                            "group": {
                                "port-group": "WAN_LAN_FORWARDING_GROUP"
                            }
                        },
                        "protocol": "tcp_udp",
                        "rule-number": 5
                    }
                ]
            },
            {
                "default-action": "accept",
                "name": "LAN-WAN-ipv4"
            },
            {
                "default-action": "accept",
                "name": "DEVICE-ANY-ipv4"
            },
            {
                "default-action": "drop",
                "name": "LAN-DEVICE-ipv4",
                "rules": [
                    {
                        "action": "accept",
                        "protocol": "icmp",
                        "rule-number": 1
                    },
                    {
                        "action": "accept",
                        "destination": {
                            "group": {
                                "port-group": "LAN_SERVICE_GROUP"
                            }
                        },
                        "protocol": "tcp_udp",
                        "rule-number": 5
                    }
                ]
            },
            {
                "default-action": "drop",
                "name": "WAN-DEVICE-ipv4",
                "rules": [
                    {
                        "action": "accept",
                        "protocol": "icmp",
                        "rule-number": 1
                    },
                    {
                        "action": "accept",
                        "destination": {
                            "group": {
                                "port-group": "WAN_SERVICE_GROUP"
                            }
                        },
                        "protocol": "tcp_udp",
                        "rule-number": 5
                    }
                ]
            }
        ],
        "zone-policies": [
            {
                "from": "WAN",
                "ruleset": "WAN-LAN-ipv4",
                "to": "LAN"
            },
            {
                "from": "LAN",
                "ruleset": "LAN-WAN-ipv4",
                "to": "WAN"
            },
            {
                "from": "DEVICE",
                "ruleset": "DEVICE-ANY-ipv4",
                "to": "WAN"
            },
            {
                "from": "WAN",
                "ruleset": "WAN-DEVICE-ipv4",
                "to": "DEVICE"
            },
            {
                "from": "DEVICE",
                "ruleset": "DEVICE-ANY-ipv4",
                "to": "LAN"
            },
            {
                "from": "LAN",
                "ruleset": "LAN-DEVICE-ipv4",
                "to": "DEVICE"
            }
        ],
        "zones": [
            {
                "default-action": "drop",
                "interfaces": [
                    "eth2",
                    "eth3"
                ],
                "name": "WAN"
            },
            {
                "default-action": "drop",
                "interfaces": [
                    "br0"
                ],
                "name": "LAN"
            },
            {
                "default-action": "drop",
                "local-zone": true,
                "name": "DEVICE"
            }
        ]
    },
    "interfaces": [
        {
            "ipv4": {
                "addressing": "dhcp"
            },
            "mtu": 1500,
            "name": "eth2",
            "role": "upstream",
            "type": "ethernet"
        },
        {
            "ipv4": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth3",
            "role": "upstream",
            "type": "ethernet"
        },
        {
            "ipv4": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth0",
            "role": "downstream",
            "type": "ethernet"
        },
        {
            "ipv4": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth1",
            "role": "downstream",
            "type": "ethernet"
        },
        {
            "ipv4": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth4",
            "role": "downstream",
            "type": "ethernet"
        },
        {
            "ipv4": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "eth5",
            "role": "downstream",
            "type": "ethernet"
        },
        {
            "bridge": {
                "members": [
                    "eth0",
                    "eth1",
                    "eth4",
                    "eth5"
                ]
            },
            "ipv4": {
                "address": [
                    "192.168.1.1/24"
                ],
                "addressing": "static"
            },
            "ipv6": {
                "addressing": "none"
            },
            "mtu": 1500,
            "name": "br0",
            "role": "downstream",
            "type": "bridge"
        },
        {
            "name": "ipsec0",
            "type": "vti",
            "ipv4": {
                "address": [
                    "10.0.0.1/24"
                ],
                "addressing": "static"
            }
        }
    ],
    "metrics": {
        "health": {
            "interval": 60
        },
        "statistics": {
            "interval": 300,
            "types": []
        }
    },
    "nat": {
        "source-ipv4": [
            {
                "outbound-interface": "eth2",
                "protocol": "all",
                "rule-number": 20,
                "source": {
                    "address": "192.168.1.0/24"
                },
                "translation": {
                    "address": "masquerade"
                }
            }
        ]
    },
    "pki": {
        "ca-certs": [
            {
                "certificate": "asdasd",
                "name": "ipsec-ca"
            }
        ],
        "certs": [
            {
                "certificate": "asdasd",
                "name": "ipsec-cert",
                "private-key": "asdasd"
            }
        ]
    },
    "services": {
        "dhcp-server": {
            "networks": [
                {
                    "name": "dhcp-br0",
                    "subnets": [
                        {
                            "default-router": "192.168.1.1",
                            "dns-servers": [
                                "192.168.1.1"
                            ],
                            "lease-time": 86400,
                            "ranges": [
                                {
                                    "start": "192.168.1.100",
                                    "stop": "192.168.1.200"
                                }
                            ],
                            "subnet": "192.168.1.0/24"
                        }
                    ]
                }
            ]
        },
        "dns": {
            "allow-from": [
                "192.168.1.0/24"
            ],
            "listen-addresses": [
                "192.168.1.1"
            ]
        },
        "ssh": {
            "expose-lan": true
        }
    },
    "system": {
        "name-servers": {
            "dhcp-interfaces": [
                "eth2"
            ]
        },
        "syslog": {
            "local": [
                {
                    "facility": "daemon",
                    "severity": "info"
                }
            ]
        }
    },
    "uuid": 1783071808,
    "vpn": {
        "ipsec": {
            "ca-cert": "ipsec-ca",
            "esp-groups": [
                {
                    "lifetime": 3600,
                    "mode": "tunnel",
                    "name": "ESP-recommended",
                    "pfs": true,
                    "proposal": [
                        {
                            "encryption": "aes256gcm128",
                            "hash": "sha384"
                        }
                    ]
                }
            ],
            "ike-groups": [
                {
                    "dead-peer-detection": {
                        "action": "restart",
                        "interval": 30
                    },
                    "key-exchange": "ikev2",
                    "lifetime": 28800,
                    "name": "IKE-recommended",
                    "proposal": [
                        {
                            "dh-group": 19,
                            "encryption": "aes256gcm128",
                            "hash": "sha384"
                        }
                    ]
                }
            ],
            "local-id": "10.0.0.1",
            "remote-access": {
                "connections": [
                    {
                        "authentication": {
                            "client-mode": "eap-mschapv2"
                        },
                        "bind": "ipsec0",
                        "connection-type": "none",
                        "dhcp-interface": "eth2",
                        "esp-group": "ESP-recommended",
                        "ike-group": "IKE-recommended",
                        "name": "remote-WAN1",
                        "pool": "CLIENTS"
                    }
                ],
                "pools": [
                    {
                        "name": "CLIENTS",
                        "name-server": "8.8.8.8",
                        "prefix": "10.0.0.0/24"
                    }
                ]
            },
            "server-cert": "ipsec-cert",
            "users": [
                {
                    "password": "shinycolors",
                    "username": "shizuka"
                }
            ]
        }
    }
}